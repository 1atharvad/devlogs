---
import { ArrowLeftIcon } from '@heroicons/react/24/solid';

import Card from '@/components/Card.astro';
import DevlogCard from '@/components/DevlogCard.astro';
import Footer from '@/components/Footer.astro';
import { Header } from '@/components/Header';
import { FilteredYearDotNav } from '@/components/FilteredYearDotNav';
import { TagFilter } from '@/components/TagFilter';
import labels from '@/content/labels.json';
import siteData from '@/content/site.json';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { categories, getCategoryPosts, getCategoryKeys, type CategoryKey } from '@/lib/categories';

export async function getStaticPaths() {
	const categoryKeys = getCategoryKeys();
	return categoryKeys.map((key) => ({
		params: { category: key },
	}));
}

const { category } = Astro.params as { category: CategoryKey };
const config = categories[category];
const posts = await getCategoryPosts(category);
const tags = ['All', ...new Set(posts.map(post => post.data.primaryTag).filter(Boolean))] as string[];

const devlogsByYear = category === 'devlogs'
	? Object.entries(
			posts.reduce((acc, post) => {
				const year = post.data.pubDate.getFullYear();
				(acc[year] ??= []).push(post);
				return acc;
			}, {} as Record<number, typeof posts>)
		).sort(([a], [b]) => Number(b) - Number(a))
	: [];

const yearNavItems = devlogsByYear.map(([year, yearPosts]) => ({
	year: Number(year),
	months: [...new Set(yearPosts.map(p => p.data.pubDate.getMonth() + 1))].sort((a, b) => b - a),
}));

const MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

const devlogsByYearAndMonth = devlogsByYear.map(([year, yearPosts]) => {
	const byMonth = Object.entries(
		yearPosts.reduce((acc, post) => {
			const month = post.data.pubDate.getMonth() + 1;
			(acc[month] ??= []).push(post);
			return acc;
		}, {} as Record<number, typeof posts>)
	).sort(([a], [b]) => Number(b) - Number(a));
	return [year, byMonth] as [string, [string, typeof posts][]];
});
---

<BaseLayout
		title={siteData.title}
		description={siteData.description}
		bodyClassName='bg-[linear-gradient(225deg,#deffbc70_30%,#ffdebf7d_70%)]'>
	<Header client:load />
	<main class="max-w-[90vw] min-h-[calc(100vh-216px)] mx-auto pb-[5vh]">
		<TagFilter tags={tags} client:load />
		<a href="/" class="inline-flex items-center min-h-[38px] font-rubik text-sm text-gray-600 pt-[6vh] mb-4 hover:underline">
			<ArrowLeftIcon className="w-4 h-4 mr-2" />
			{labels.navigation.home}
		</a>
		<section>
			<h3 class="font-rubik text-3xl pb-6">
				{config.title}
			</h3>
			{category === 'devlogs' ? (
				<div class="flex flex-col">
					<FilteredYearDotNav items={yearNavItems} client:load />
					{devlogsByYearAndMonth.map(([year, monthGroups]) => (
						<div id={`year-${year}`} class="relative">
							{monthGroups.map(([month, monthPosts]) => (
								<div id={`year-${year}-month-${month}`} class="js-month-group relative">
									<div class="sticky top-[70px] z-10 flex justify-start py-2 pointer-events-none">
										<span class="font-rajdhani font-semibold text-xs tracking-widest uppercase text-white bg-orange-500 rounded-full px-2.5 py-1 shadow-md shadow-orange-200 pointer-events-auto">
											{MONTH_NAMES[Number(month) - 1]} {year}
										</span>
									</div>
									{monthPosts.map((post) => (
										<DevlogCard id={post.id} post={post.data} link={`/${category}`} />
									))}
								</div>
							))}
						</div>
					))}
					<div class="my-10 flex justify-center">
						<div class="flex flex-col items-center text-center gap-2 bg-slate-400/10 rounded-2xl px-10 py-8 max-w-md">
							<span class="text-3xl">🚧</span>
							<p class="font-rajdhani font-semibold text-xl text-zinc-700">More on the way</p>
							<p class="font-rubik text-sm text-zinc-400">This is a living record of what I'm building — new entries added as projects evolve.</p>
						</div>
					</div>
				</div>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10 list-none m-0 p-0">
					{posts.map((post) => (
						<Card id={post.id} post={post.data} link={`/${category}`} />
					))}
				</div>
			)}
		</section>
	</main>
	<Footer />
</BaseLayout>
