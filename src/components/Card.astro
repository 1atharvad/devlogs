---
import type { ImageMetadata } from 'astro';

import { Badge, Card as AdviCard, CardWrapper, CardTitle, CardDescription } from 'advi-ui';

import FormattedDate from '@/components/FormattedDate.astro';
import Image from '@/components/Image.astro';

interface Props {
  id: string;
  post: {
    title: string;
    description: string;
    pubDate: Date;
    heroImage?: ImageMetadata;
    primaryTag?: string;
    tags?: string[];
  };
  link: string;
}

const { id, post, link } = Astro.props;
const allTags = [post.primaryTag, ...(post.tags || [])].filter(Boolean) as string[];
---

<a href={`${link}/${id}`} class="js-post-card group block" data-primary-tag={post.primaryTag || ''}>
  <AdviCard className="h-full !bg-slate-400/[.1] !border-0 !shadow-none !rounded-2xl p-4">
    {post.heroImage && (
      <div class="relative">
        <Image
          src={post.heroImage}
          alt={post.title}
          class="rounded-2xl w-full"
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
        />
        <FormattedDate
          date={post.pubDate}
          class="absolute top-0 right-0 inline-flex items-center rounded-full font-rubik border border-white/70 px-2.5 py-1.5 m-2.5 text-xs font-semibold text-white/80"
        />
      </div>
    )}
    <CardWrapper className="!p-0">
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {allTags.map((tag) => (
            <Badge variant="secondary" size="sm" className="font-rubik uppercase !bg-zinc-300/50 !text-zinc-600">
              {tag}
            </Badge>
          ))}
        </div>
      )}
      <CardTitle className="font-rubik text-lg mt-2 !tracking-normal group-hover:text-orange-600 transition-colors" style={{ fontWeight: 'inherit' }}>{post.title}</CardTitle>
      <CardDescription className="font-rubik">{post.description}</CardDescription>
    </CardWrapper>
  </AdviCard>
</a>
